# Font
font-family = JetBrains Mono
font-size = 12

# Cursor
cursor-style = block
# cursor-blink = false

# Scroll
# scrollback-lines = 10000

# Themes
# theme = Dracula
theme = Gruvbox Dark

# Background
background-opacity = 0.7
background-blur-radius = 16

# Window
window-padding-x = 6
window-padding-y = 6
background-opacity = 0.97

# macOS
macos-titlebar-style = transparent
macos-option-as-alt = true

# Send Alt+Arrow as xterm CSI modifier seq (zellij tab nav)
keybind = alt+arrow_left=csi:1;3D
keybind = alt+arrow_right=csi:1;3C

