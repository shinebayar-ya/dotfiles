# Font
font-family = JetBrains Mono
font-size = 12

# Cursor
cursor-style = block
# cursor-blink = false

# Scroll
# scrollback-lines = 10000

# Themes
theme = Github Light Colorblind

# Background
background-opacity = 0.95
background-blur-radius = 16

# Window
window-padding-x = 6
window-padding-y = 6

# macOS
macos-titlebar-style = transparent
macos-option-as-alt = true

# ssh
# Auto-inject ghostty terminfo + TERM env into remote sessions.
# Fixes backspace, arrows, colors on hosts without xterm-ghostty terminfo.
# Requires shell integration (enabled by default).
shell-integration-features = ssh-env,ssh-terminfo
